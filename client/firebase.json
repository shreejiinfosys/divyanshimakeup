{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/", "destination": "/pages/index.html" },
      { "source": "/404", "destination": "/pages/404.html" }
    ],
    "headers": [
      { "source": "**/*.@(html)", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
      { "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico|woff|woff2|ttf)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
    ]
  }
}
